# Copy this file to .env and fill in values from your APS app:
# https://aps.autodesk.com/myapps

# Option A: two-legged token (server / automation)
APS_CLIENT_ID=your_client_id_here
APS_CLIENT_SECRET=your_client_secret_here

# Option B: use a pre-obtained bearer token (e.g. three-legged); overrides client credentials
# APS_ACCESS_TOKEN=your_access_token_here
